[Unit]
Description=Telegram MCP Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=i-b8o
Group=i-b8o
WorkingDirectory=/home/i-b8o/src/github.com/bogachenko/telegram-mcp-server
EnvironmentFile=/etc/telegram-mcp-server.env
ExecStart=/usr/local/bin/telegram-mcp-server serve
Restart=on-failure
RestartSec=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false

[Install]
WantedBy=multi-user.target
