# Copy this file to:
#
#   sudo cp .env.example /etc/telegram-mcp-server.env
#   sudo nano /etc/telegram-mcp-server.env
#   sudo chmod 600 /etc/telegram-mcp-server.env
#
# Do not commit real values.

TGMCP_TELEGRAM_API_ID=
TGMCP_TELEGRAM_API_HASH=
TGMCP_TELEGRAM_PHONE=

# Optional, only if Telegram 2FA password is enabled.
# TGMCP_TELEGRAM_PASSWORD=

TGMCP_LISTEN_ADDR=127.0.0.1:1984
TGMCP_PUBLIC_BASE_URL=https://tg-mcp.elektrosila-avtomatika.store

# OAuth authorization-code mode.
# The owner enters this token on /oauth/authorize.
TGMCP_OAUTH_OWNER_TOKEN=

# Background watcher: sync all enabled sources every 300 seconds.
TGMCP_WATCH_ENABLED=true
TGMCP_WATCH_INTERVAL_SECONDS=300
TGMCP_WATCH_LIMIT=1000

# Optional Telegram Bot API notifications.
# Sends one summary message after watcher sync when new messages were saved.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
