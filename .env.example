# Telegram MCP local env template.
#
# Do not commit real values.
# For CLI usage you can export these from ~/.bashrc.
# For systemd usage copy this file to:
#
#   /home/i-b8o/.config/telegram-mcp-server/env
#
# and set:
#
#   chmod 600 /home/i-b8o/.config/telegram-mcp-server/env

TGMCP_TELEGRAM_API_ID=
TGMCP_TELEGRAM_API_HASH=
TGMCP_TELEGRAM_PHONE=

# Optional, only if Telegram 2FA password is enabled.
# TGMCP_TELEGRAM_PASSWORD=

# Static bearer token mode.
# The MCP client must send:
#   Authorization: Bearer <this-token>
TGMCP_BEARER_TOKEN=

# OAuth authorization-code mode.
# Use this instead of, or in addition to, TGMCP_BEARER_TOKEN.
# The owner enters this token on /oauth/authorize.
# TGMCP_OAUTH_OWNER_TOKEN=
